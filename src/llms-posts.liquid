---
pagination:
  data: collections.post
  size: 1
  alias: post
permalink: "/blog/{{ post.fileSlug }}.md"
eleventyExcludeFromCollections: true
eleventyComputed:
  title: "{{ post.data.title }}"
---
# {{ post.data.title }}

Date: {{ post.date | dateFormat }}
Author: {{ users[post.data.author].fullname | default: post.data.author }}
Tags: {{ post.data.tags | join: ", " }}

{{ post.inputPath | rawMarkdown }}
