AddCharset UTF-8 .txt .md
AddType text/markdown .md

# Custom 404
ErrorDocument 404 /404.html

# HTTP Link headers: sitemap + llms.txt
<IfModule mod_headers.c>
  Header always set Link "</sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\""
  Header always append Link "</llms.txt>; rel=\"alternate\"; type=\"text/plain\""
</IfModule>

# Security response headers
<IfModule mod_headers.c>
  # Force HTTPS for a year (ignored by browsers over plain HTTP, e.g. local dev)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Stop MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Clickjacking protection: modern (CSP) + legacy fallback
  Header always set Content-Security-Policy "frame-ancestors 'self'"
  Header always set X-Frame-Options "SAMEORIGIN"
  # Limit referrer leakage
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Deny powerful features by default
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
</IfModule>

# Caching
<IfModule mod_headers.c>
  # Fingerprinted stylesheets/scripts (URL carries ?v=<hash>) — cache permanently
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Fonts, icons and images — cache a week, then revalidate
  <FilesMatch "\.(woff2?|ttf|eot|ico|png|jpe?g|gif|svg|webp|avif)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  # HTML and machine-readable endpoints — always revalidate
  <FilesMatch "\.(html|xml|json|txt|md)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/markdown \
    text/xml application/xml application/rss+xml application/json \
    application/javascript image/svg+xml
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/markdown \
    text/xml application/xml application/rss+xml application/json \
    application/javascript image/svg+xml
</IfModule>

# Content negotiation: text/markdown → .md files
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Blog posts: /blog/slug/ → /blog/slug.md when Accept: text/markdown
  RewriteCond %{HTTP_ACCEPT} text/markdown
  RewriteRule ^blog/([^/]+)/$ /blog/$1.md [L,R=303]

  # About: /about/ → /about.md
  RewriteCond %{HTTP_ACCEPT} text/markdown
  RewriteRule ^about/$ /about.md [L,R=303]

  # Contact: /contact/ → /contact.md
  RewriteCond %{HTTP_ACCEPT} text/markdown
  RewriteRule ^contact/$ /contact.md [L,R=303]

  # Privacy: /privacy/ → /privacy.md
  RewriteCond %{HTTP_ACCEPT} text/markdown
  RewriteRule ^privacy/$ /privacy.md [L,R=303]

  # Author: /author/slug/ → /author/slug.md
  RewriteCond %{HTTP_ACCEPT} text/markdown
  RewriteRule ^author/([^/]+)/$ /author/$1.md [L,R=303]
</IfModule>

# Security: block access to sensitive files
<IfModule mod_rewrite.c>
  RewriteRule ^api/config\.json$ - [F,L]
  RewriteRule ^api/lib/ - [F,L]
  RewriteRule ^api/logs/ - [F,L]
  RewriteRule ^api/mail/ - [F,L]
  RewriteRule ^vendor/ - [F,L]
  RewriteRule ^api/composer\.(json|lock)$ - [F,L]
  RewriteRule \.db$ - [F,L]
</IfModule>

# Search: rewrite /search/ to PHP handler
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_FILENAME}/index.php -f
  RewriteRule ^search/$ /search/index.php [L,QSA]
</IfModule>
