<div class="subscribe">
  <div class="subscribe__inner">
    <h2>Get the next post by email</h2>
    <p>One short note when something new is published. No tracking, no ads, easy to unsubscribe.</p>
    <div class="form-message" data-form-message role="status" aria-live="polite"></div>
    <form class="subscribe-form" data-form="subscribe" novalidate>
      <input class="input" type="email" name="email" placeholder="you@example.com" aria-label="Email address" required />
      <button class="btn btn-primary" type="submit">Subscribe</button>
      <div class="hp" aria-hidden="true">
        <label for="sub-website">Website</label>
        <input id="sub-website" type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>
    </form>
    <p class="privacy-note">By subscribing you accept the <a href="/privacy/">privacy policy</a>.</p>
  </div>
</div>
