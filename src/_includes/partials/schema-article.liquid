{% assign postAuthor = users[author] %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {{ person | jsonify }},
    {
      "@type": "BlogPosting",
      "@id": "{{ site.url }}{{ page.url }}#article",
      "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
      "headline": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ date | dateFormat: 'iso' }}",
      "dateModified": "{{ modified | default: date | dateFormat: 'iso' }}",
      "author": {
        "@type": "Person",
        "name": "{% if postAuthor %}{{ postAuthor.fullname }}{% else %}{{ author }}{% endif %}",
        "url": "{{ site.url }}/author/{{ author }}/"
      },
      "publisher": { "@id": "{{ site.url }}/#author" },
      "image": "{{ site.url }}{{ featuredImage | default: site.socialImage }}",
      "inLanguage": "{{ site.language }}",
      "isPartOf": { "@id": "{{ site.url }}/#blog" }{% if keywords %},
      "keywords": "{{ keywords }}"{% endif %}
    },
    {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}#webpage",
      "url": "{{ site.url }}{{ page.url }}",
      "name": "{{ title }} — {{ site.title }}",
      "isPartOf": { "@id": "{{ site.url }}/#website" },
      "datePublished": "{{ date | dateFormat: 'iso' }}",
      "dateModified": "{{ modified | default: date | dateFormat: 'iso' }}",
      "inLanguage": "{{ site.language }}"
    },
    {
      "@type": "Blog",
      "@id": "{{ site.url }}/#blog",
      "url": "{{ site.url }}/blog/",
      "name": "{{ site.title }} Blog",
      "publisher": { "@id": "{{ site.url }}/#author" }
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.url }}/#website",
      "url": "{{ site.url }}/",
      "name": "{{ site.title }}",
      "publisher": { "@id": "{{ site.url }}/#author" },
      "inLanguage": "{{ site.language }}"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ site.url }}{{ page.url }}#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ site.url }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": "{{ site.url }}/blog/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ title }}",
          "item": "{{ site.url }}{{ page.url }}"
        }
      ]
    }
  ]
}
</script>
